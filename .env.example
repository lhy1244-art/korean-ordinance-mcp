# --- LLM (Anthropic API) ---

# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional model overrides
# ANTHROPIC_MODEL_REASONING=claude-sonnet-4-6
# ANTHROPIC_MODEL_SUMMARY=claude-haiku-4-5-20251001

# 국가법령정보센터 DRF OPEN API — sign up at https://open.law.go.kr,
# apply for OPEN API and register your IP. OC value is the local part of
# your signup email. One key covers both 자치법규(ordin) and 법령(law) targets.
# LAW_GO_KR_OC=

# Demo mode: use cached/seed data, do not hit live APIs
DEMO_MODE=false

# Cache TTL in hours
CACHE_TTL_HOURS=24
